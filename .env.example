# --- Privy embedded wallet ---
# Required: your Privy App ID from https://dashboard.privy.io
VITE_PRIVY_APP_ID=

# Optional: Privy client ID for multi-domain deployments
# VITE_PRIVY_CLIENT_ID=

# --- x402 payment settings ---
# Use testnet mode (Base Sepolia). Set to "false" for mainnet (Base).
VITE_X402_TESTNET=true

# Default max USDC (micro-units, 6 decimals) per x402 payment.
# 10_000_000 = 10 USDC
# VITE_X402_MAX_VALUE=10000000

# --- Backend API ---
# Base URL for the Aurelia backend (default: http://127.0.0.1:8787)
# VITE_API_BASE_URL=http://127.0.0.1:8787
