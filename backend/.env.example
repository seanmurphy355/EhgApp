# Optional: override to use external Postgres
# DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/aurelia

# Optional: override default instance root (%USERPROFILE%\\.aurelia\\instances\\default)
# AURELIA_INSTANCE_ROOT=C:\\Users\\Owner\\.aurelia\\instances\\default

AURELIA_BACKUP_INTERVAL_MINUTES=60
AURELIA_BACKUP_RETENTION_DAYS=30